# ========================================
# Underground Arena — Environment Variables
# ========================================
# Copy this file to .env and fill in your values

# --- App ---
NODE_ENV=development
PORT=3001

# --- Database ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=arena_user
DB_PASSWORD=arena_secret_password
DB_NAME=underground_arena

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_this_too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- OAuth Google ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# --- OAuth Discord ---
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_CALLBACK_URL=http://localhost:3001/api/auth/discord/callback

# --- Frontend ---
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# --- Platform Settings ---
PLATFORM_COMMISSION_RATE=0.10
INITIAL_CREDITS=1000
